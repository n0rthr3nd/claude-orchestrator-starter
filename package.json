{
  "name": "claude-orchestrator",
  "version": "1.0.0",
  "description": "Production-ready multi-agent orchestrator using Claude Code as central coordinator",
  "type": "module",
  "main": "src/orchestrator.js",
  "scripts": {
    "start": "node src/orchestrator.js",
    "orchestrate": "node src/orchestrator.js",
    "checkpoint": "node src/checkpoint-manager.js save",
    "rollback": "node src/checkpoint-manager.js restore",
    "status": "node src/orchestrator.js status",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "jest --coverage",
    "validate-schemas": "node scripts/validate-schemas.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "uuid": "^11.0.0",
    "js-yaml": "^4.1.0",
    "ajv": "^8.17.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "commander": "^13.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "p-limit": "^6.1.0",
    "p-retry": "^6.2.0",
    "hash-object": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2"
  },
  "jest": {
    "transform": {},
    "extensionsToTreatAsEsm": [".js"],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 80,
        "functions": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
