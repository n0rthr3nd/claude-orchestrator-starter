{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orchestrator/schemas/agent-output.json",
  "title": "AgentOutput",
  "description": "Standardized output format for all specialist agents",
  "type": "object",
  "required": ["agent", "task_id", "confidence_score", "artifacts", "quality_gates_passed"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": ["architect", "developer", "reviewer", "tester", "security", "documenter"]
    },
    "task_id": { "type": "string", "format": "uuid" },
    "confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Agent's self-assessed confidence in output quality"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "quality_gates_passed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["static_analysis", "tests", "security", "documentation", "code_review"]
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "request_changes", "block", "pass", "fail", "conditional"]
    },
    "findings": {
      "type": "array",
      "description": "Issues found (used by reviewer and security agents)",
      "items": {
        "type": "object",
        "required": ["id", "severity", "message"],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "message": { "type": "string" },
          "suggestion": { "type": "string" },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "summary": { "type": "string" },
    "escalation_notes": { "type": "string" },
    "tokens_used": { "type": "integer" },
    "duration_ms": { "type": "integer" }
  }
}
