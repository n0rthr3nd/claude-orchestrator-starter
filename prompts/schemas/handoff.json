{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orchestrator/schemas/handoff.json",
  "title": "AgentHandoff",
  "description": "Structured handoff packet between orchestrator agents",
  "type": "object",
  "required": ["handoff"],
  "properties": {
    "handoff": {
      "type": "object",
      "required": ["from_agent", "to_agent", "task_id", "timestamp", "context_summary"],
      "properties": {
        "from_agent": {
          "type": "string",
          "enum": ["orchestrator", "architect", "developer", "reviewer", "tester", "security", "documenter"],
          "description": "Agent producing this handoff"
        },
        "to_agent": {
          "type": "string",
          "enum": ["orchestrator", "architect", "developer", "reviewer", "tester", "security", "documenter"],
          "description": "Agent receiving this handoff"
        },
        "task_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this task chain"
        },
        "session_id": {
          "type": "string",
          "description": "Orchestration session this belongs to"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "context_summary": {
          "type": "string",
          "maxLength": 3000,
          "description": "Compressed context summary (<500 words)"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "path"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file", "spec", "test", "diagram", "report", "schema", "config"]
              },
              "path": { "type": "string" },
              "hash": { "type": "string", "description": "SHA-256 of artifact content" },
              "description": { "type": "string" }
            }
          }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Technical or business constraints the receiving agent must respect"
        },
        "quality_gates_passed": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["static_analysis", "tests", "security", "documentation", "code_review"]
          }
        },
        "confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Confidence in this output (0-100)"
        },
        "next_expected_output": {
          "type": "object",
          "properties": {
            "format": { "type": "string", "enum": ["json", "code", "markdown", "yaml"] },
            "artifacts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "acceptance_criteria": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "escalation_notes": {
          "type": "string",
          "description": "Blockers, concerns, or questions that need orchestrator attention"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "default": 0
        }
      }
    }
  }
}
