# Claude Orchestrator — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Agent models (defaults are cost-optimized)
ORCHESTRATOR_MODEL=claude-opus-4-6
DEFAULT_SUB_AGENT_MODEL=claude-sonnet-4-6

# Execution limits
MAX_PARALLEL_AGENTS=3
MAX_RETRIES=2
CONFIDENCE_THRESHOLD=80
MAX_CONTEXT_TOKENS=80000
COMPRESSION_THRESHOLD=60000

# Storage
CHECKPOINT_DIR=.orchestrator/checkpoints
CACHE_DIR=.orchestrator/cache

# Logging
LOG_LEVEL=info
NODE_ENV=development
